{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram/refs/heads/main/src-tauri/tauri.conf.json",
  "productName": "Bearpad 2",
  "version": "0.1.0",
  "identifier": "com.merlinjkd.bearpad2",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Bearpad 2",
        "width": 1000,
        "height": 700
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "clipboard-manager": {}
  }
}
